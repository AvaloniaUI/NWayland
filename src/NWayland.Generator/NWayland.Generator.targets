<Project>
    <ItemGroup>
        <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="NWaylandNamespace" />
        <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="NWaylandVisibility" />
        <CompilerVisibleProperty Include="NWayland_ArrayHints" />
        <CompilerVisibleProperty Include="NWayland_DefaultVisibility" />
        <NWaylandArrayHint Update="@(NWaylandArrayHint)" Visible="false" />
        
    </ItemGroup>
    <PropertyGroup>
        <NWayland_ArrayHints>@(NWaylandArrayHint -> '%(Identity)', '|')</NWayland_ArrayHints>
    </PropertyGroup>
    <ItemGroup>
        <NWaylandArrayHint Remove="@(NWaylandArrayHint)"/>
    </ItemGroup>
        
</Project>